{
  "manifest_version": 3,
  "name": "GetShift — Assistant Productivité",
  "short_name": "GetShift",
  "version": "1.0.0",
  "description": "Détecte automatiquement tes cours Zoom, fichiers Drive et pages Notion pour créer des tâches GetShift en un clic.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "identity"
  ],
  "host_permissions": [
    "https://*.zoom.us/*",
    "https://meet.google.com/*",
    "https://calendar.google.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://www.notion.so/*",
    "https://app.slack.com/*",
    "https://discord.com/*",
    "https://getshift-backend.onrender.com/*",
    "https://chamdaane-a11y.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zoom.us/j/*",
        "https://meet.google.com/*",
        "https://calendar.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://www.notion.so/*",
        "https://app.slack.com/*",
        "https://discord.com/channels/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GetShift"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
